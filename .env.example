# ──────────────────────────────────────────────
# Banco de dados — Data Warehouse
# ──────────────────────────────────────────────
DW_HOST=localhost
DW_PORT=5432
DW_DB=unimed_dw
DW_USER=dw_user
DW_PASSWORD=dw_password

# ──────────────────────────────────────────────
# Banco de dados — Airflow metadata
# ──────────────────────────────────────────────
AIRFLOW_DB=airflow
AIRFLOW_USER=airflow
AIRFLOW_PASSWORD=airflow
AIRFLOW_PORT=5433          # porta externa diferente do DW

# ──────────────────────────────────────────────
# Airflow
# ──────────────────────────────────────────────
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__WEBSERVER__SECRET_KEY=troque-esta-chave-em-producao
AIRFLOW_UID=50000

# ──────────────────────────────────────────────
# Caminhos
# ──────────────────────────────────────────────
RAW_DATA_PATH=/opt/airflow/data/raw
DUCKDB_PATH=/tmp/unimed_staging.duckdb

# ──────────────────────────────────────────────
# Unimed Fortaleza — referência
# ──────────────────────────────────────────────
REGISTRO_ANS_UNIMED_FORTALEZA=359017
